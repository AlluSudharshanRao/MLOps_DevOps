# Copy to values-secret.yaml (gitignored) and replace every placeholder.
# Ref: https://github.com/zulip/docker-zulip/blob/main/helm/zulip/values-local.yaml.example
#
# SETTING_EXTERNAL_HOST must match how browsers reach Zulip (DNS, nip.io, or IP if your setup allows).
#
# Helm/Bitnami require passwords as strings. If a password is only digits, YAML treats it as a
# number unless you quote it — use double quotes for every secret below.
#
# STRUCTURE (critical): Only `zulip:` + `environment:` belongs under `zulip`.
# memcached, rabbitmq, redis, and postgresql MUST be top-level keys (same indent as `zulip:`),
# NOT nested under `zulip:`. Wrong indent causes:
#   - "zulip.postgresql.auth" / coalesce warnings
#   - "type mismatch on memcached"
# Use two spaces per indent. Put a newline after `memcached:` — do not put
# `memcachedPassword` on the same line as `memcached:`.

zulip:
  environment:
    SETTING_EXTERNAL_HOST: "zulip.example.com"
    SETTING_ZULIP_ADMINISTRATOR: "admin@example.com"
    SECRETS_secret_key: "replace-with-long-random-string"

memcached:
  memcachedPassword: "replace-with-secure-password"

rabbitmq:
  auth:
    password: "replace-with-secure-password"
    erlangCookie: "replace-with-secure-erlang-cookie"

redis:
  auth:
    password: "replace-with-secure-password"

postgresql:
  auth:
    postgresqlPassword: "replace-with-secure-postgres-admin-password"
    password: "replace-with-secure-zulip-db-password"
